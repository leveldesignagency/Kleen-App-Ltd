NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NEXT_PUBLIC_SITE_URL=http://localhost:3100

# Resend: set RESEND_FROM_VERIFIED=true once kleenapp.co.uk is verified in Resend
# RESEND_FROM_VERIFIED=true
# RESEND_FROM_EMAIL=Kleen <info@kleenapp.co.uk>

# Stripe (customer payments + escrow)
STRIPE_SECRET_KEY=sk_test_...
# For local dev: run `stripe listen --forward-to localhost:3100/api/stripe/webhook` and use the printed whsec_... value
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Resend — admin email when customer accepts a quote (same key as kleen-admin; optional until you test webhooks)
# RESEND_API_KEY=re_...
# ADMIN_NOTIFY_EMAIL=info@kleenapp.co.uk
# ADMIN_APP_URL=https://admin.kleenapp.co.uk
