NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NEXT_PUBLIC_SITE_URL=http://localhost:3100
# Optional: where “Sign out” sends users (defaults to www on dashboard subdomain). e.g. https://www.kleenapp.co.uk
# NEXT_PUBLIC_MARKETING_URL=https://www.kleenapp.co.uk

# Set true only if you need email/password on /sign-in (default: Google only)
# NEXT_PUBLIC_ENABLE_EMAIL_AUTH=true

# Resend — admin notifications (new job, quote accepted)
# RESEND_API_KEY=re_...
# ADMIN_NOTIFY_EMAIL=info@kleenapp.co.uk
#
# Wix / DNS: if you cannot verify kleenapp.co.uk in Resend yet, use Resend’s sender
# and force it (do not set RESEND_FROM_VERIFIED=true until the domain shows “Verified” in Resend):
# RESEND_FORCE_ONBOARDING=true
# Optional: replies go here while “from” is onboarding@resend.dev
# RESEND_REPLY_TO=info@kleenapp.co.uk
#
# When DNS is on Cloudflare (or Wix allows Resend’s TXT/CNAME), verify the domain in Resend, then:
# RESEND_FROM_VERIFIED=true
# RESEND_FROM_EMAIL=Kleen <info@kleenapp.co.uk>

# Stripe (customer payments + escrow)
STRIPE_SECRET_KEY=sk_test_...
# For local dev: run `stripe listen --forward-to localhost:3100/api/stripe/webhook` and use the printed whsec_... value
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ADMIN_APP_URL=https://admin.kleenapp.co.uk

# Vercel Cron: purge accounts past scheduled deletion (Bearer token for GET /api/cron/purge-deleted-accounts)
# CRON_SECRET=generate-a-long-random-string
