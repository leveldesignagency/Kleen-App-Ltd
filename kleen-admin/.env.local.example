# Same Supabase project as kleen-app — same credentials
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Local dev: admin = 3101, customer kleen-app = 3100. Supabase Redirect URLs must include this origin.
# NEXT_PUBLIC_SITE_URL=http://localhost:3101

# Contractor portal (kleen-contractor deployment), e.g. https://contractors.kleenapp.co.uk — used in admin emails to contractors
# CONTRACTOR_PORTAL_BASE_URL=https://contractors.kleenapp.co.uk
# RESEND_FROM_VERIFIED=true
# RESEND_FROM_EMAIL=Kleen <info@kleenapp.co.uk>
# Live admin URL (optional; for redirects / links).
# NEXT_PUBLIC_SITE_URL=https://admin.kleenapp.co.uk

# Required for Release funds (Stripe Connect payouts to contractors)
STRIPE_SECRET_KEY=sk_test_...
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: Vercel Cron (or any scheduler) — GET /api/cron/release-due-funds with Authorization: Bearer <secret>
# Auto-releases completed jobs after escrow_release_date. Generate a long random string.
# CRON_SECRET=

# Email: contractor "Forward Full Spec" + customer "quotes ready". Only RESEND_API_KEY required; sends from onboarding@resend.dev.
# Get API key at https://resend.com → API Keys. Set in kleen-admin only (Vercel: kleen-admin project env vars).
RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=  # optional; if unset, uses "Kleen <onboarding@resend.dev>" (no domain verification)
# CUSTOMER_DASHBOARD_URL=https://dashboard.kleenapp.co.uk  # optional; link in customer quote emails
