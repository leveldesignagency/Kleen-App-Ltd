# Same Supabase project as kleen-app — same credentials
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Live admin URL (optional; for redirects / links). Supabase Redirect URLs must include this origin.
# NEXT_PUBLIC_SITE_URL=https://admin.kleenapp.co.uk

# Required for Release funds (Stripe Connect payouts to contractors)
STRIPE_SECRET_KEY=sk_test_...
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: email job details to contractor when admin clicks "Forward Full Spec"
# Optional: email customer when admin sends quote(s) to customer ("quotes ready in your dashboard")
# Get API key at https://resend.com — use onboarding@resend.dev as from-address for testing
RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL="Kleen <hello@yourdomain.com>"  # optional; defaults to onboarding@resend.dev
# CUSTOMER_DASHBOARD_URL=https://dashboard.kleenapp.co.uk  # optional; link in customer quote emails
